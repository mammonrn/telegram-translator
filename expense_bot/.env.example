# --- Telegram ---
BOT_TOKEN=123456789:AAExampleTelegramBotTokenHere

# Comma-separated Telegram user IDs allowed to use the bot. Leave empty to
# allow anyone (not recommended for a personal finance bot).
ALLOWED_USER_IDS=

# --- Google service account ---
# Path to the downloaded service-account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# ID of the Drive folder that will contain (or already contains) the
# "Expenses" root folder. This is the *parent* folder, e.g. a shared drive
# or "My Drive" folder the service account has Editor access to.
GOOGLE_DRIVE_FOLDER_ID=your-drive-parent-folder-id

# Optional: separate Drive folder to store daily spreadsheet backups.
# Defaults to the same folder as GOOGLE_DRIVE_FOLDER_ID if unset.
GOOGLE_DRIVE_BACKUP_FOLDER_ID=

# ID of the Google Sheet (from its URL) used to store expense records.
SPREADSHEET_ID=your-google-sheet-id

# --- Behaviour ---
TIMEZONE=Asia/Bangkok
LOG_FILE=expense_bot.log
LOG_LEVEL=INFO

# Minimum OCR confidence (0-1) required before the bot trusts the extracted
# amount. Below this, the user is asked to type the amount manually.
OCR_CONFIDENCE_THRESHOLD=0.55

# Only needed if pytesseract can't find the tesseract binary automatically.
TESSERACT_CMD=

# Hour (UTC, 0-23) at which the daily Google Sheet backup job runs.
DAILY_BACKUP_HOUR_UTC=18

# Local file used to cache Google Drive folder IDs between restarts.
DRIVE_FOLDER_CACHE_PATH=.drive_folder_cache.json
